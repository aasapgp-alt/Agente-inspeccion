# Configuración del Agente de Inspección
# API key de Gemini. La tabla `configuracion` de la BD (clave `google_api_key`,
# editable desde el panel de Configuración) tiene prioridad; esta variable es el
# respaldo cuando esa clave está vacía.
GEMINI_API_KEY=tu_clave_de_api_aquí
JWT_SECRET=supersecretkey_cambiar_en_produccion
DB_PATH=data/inspecciones.db
