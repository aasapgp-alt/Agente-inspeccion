# Configuración del Agente de Inspección
# API key de Gemini. La tabla `configuracion` de la BD (clave `google_api_key`,
# editable desde el panel de Configuración) tiene prioridad; esta variable es el
# respaldo cuando esa clave está vacía.
GEMINI_API_KEY=tu_clave_de_api_aquí
JWT_SECRET=supersecretkey_cambiar_en_produccion
DB_PATH=data/inspecciones.db

# Contraseña inicial del usuario 'admin' que siembra init_db. Si se deja sin
# definir, init_db genera una aleatoria y la imprime UNA sola vez en consola.
ADMIN_INITIAL_PASSWORD=cambiar_en_primer_uso

# Desactiva la verificación de certificados SSL (INSEGURO). Úsese solo en
# entornos locales de Windows con problemas de certificados. Vacío = seguro.
DISABLE_SSL_VERIFY=
